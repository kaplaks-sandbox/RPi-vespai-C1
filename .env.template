# VespAI Configuration
# Copy to .env and customize for your setup
VESPAI_NAME="VespAI-C1"
# SMS Alert Configuration (Optional)
# LOX24_API_KEY=your_api_key_here
# PHONE_NUMBER=+1234567890
# DOMAIN_NAME=your-domain.com
ENABLE_SMS=false
SMS_DELAY_MINUTES=5

#PushOver Configuration (Optional)
#PUSHOVER_USER=_put the key that's on the top right of your Pushover home screen and probably starts with a u_  
#PUSHOVER_USER=your_user_key_here
#
#PUSHOVER_TOKEN=_put the key when you click into your new application called Agents (or whatever) and probably starts with an a_
#PUSHOVER_TOKEN=your_app_token_here
ENABLE_PUSH=true
PUSH_DELAY_MINUTES=5


# Model Configuration
# Use ONNX by default so startup does not require NCNN/PyTorch runtime.
MODEL_PATH=models/L2_2026-03-25_13-42-18_best.onnx
VESPAI_MODEL_FORMAT=onnx
CONFIDENCE_THRESHOLD=0.30
# Leave blank for the current YOLO26 export so embedded labels are used as-is.
VESPAI_CLASS_MAP=
VESPAI_DATASET_PATH="datasets/test"

# Camera Configuration
# Easy camera backend selection:
# - usb: use /dev/video* devices (webcams, USB capture)
# - picamera2: use Raspberry Pi CSI camera (Camera Module 3)
# - auto: try USB first, then Picamera2 fallback
#VESPAI_CAMERA_SOURCE=Picamera2
#CAMERA_INDEX=

# Leave empty in auto mode unless forcing a specific /dev/video* node
# VESPAI_CAMERA_DEVICE=
# Quick switch examples:
VESPAI_CAMERA_SOURCE=picamera2
VESPAI_CAMERA_DEVICE=
# Optional camera alias shown in logs/UI (max 16 chars)
VESPAI_CAMERA_ALIAS="Front Camera"

#VESPAI_CAMERA_SOURCE=auto
#VESPAI_CAMERA_DEVICE=/dev/video8

RESOLUTION=1280x720
CAMERA_RESOLUTION=1280x720
CAMERA_FPS=30
# Camera capture quality: 'max' uses backend max; or set 1-100 to lower quality
CAMERA_IMAGE_QUALITY=max
# Autofocus (Picamera2 only): true or false
VESPAI_CAMERAPI_AUTOFOCUS=true
# Pi Camera Module tuning (Picamera2 only)
VESPAI_CAMERAPI_FOCUS_MODE=manual
VESPAI_CAMERAPI_FOCUS_DISTANCE_M=0.13
# AWB MODE = 
#auto
#incandescent
#tungsten
#fluorescent
#indoor
#daylight
#cloudy
#off
#custom
#manual
VESPAI_CAMERAPI_AWB_MODE=auto
VESPAI_CAMERAPI_AWB_RED_GAIN=0.0
VESPAI_CAMERAPI_AWB_BLUE_GAIN=0.0
VESPAI_CAMERAPI_COLOR_ORDER=bgr
WEB_COLOR_SCALE_R=1.0
WEB_COLOR_SCALE_G=1.0
WEB_COLOR_SCALE_B=1.0



# Object tracking mode:
# - off: no tracking IDs
# - centroid: distance-based matching (fast)
# - iou: IoU-based matching
VESPAI_TRACKING_MODE=centroid

# Detection Configuration
SAVE_DETECTIONS=true
SAVE_DIRECTORY=monitor/detections
DETECTION_RETENTION_DAYS=21
DETECTION_MAX_FILE_COUNT=250
FRAME_DELAY=0.35
DATASET_FRAME_DELAY=5.0

# Motion Detection (Optional)
ENABLE_MOTION_DETECTION=true
MIN_MOTION_AREA=5000

# Web Interface
WEB_HOST=0.0.0.0
WEB_PORT=8081
WEB_PREVIEW_SIZE=960x540
LIVE_STREAM_QUALITY=72
CURRENT_FRAME_QUALITY=82
